/**
 * @file .gitignore
 * @description Specifies intentionally untracked files that Git should ignore.
 * Groups include dependencies, environment secrets, build outputs, and OS junk.
 */

/** * @section Dependencies
 * @desc Ignore all node_modules folders (local and nested).
 */
**/node_modules/
node_modules/

/** * @section Security & Environment
 * @desc Prevent sensitive keys, passwords, and local configs from leaking to the repository.
 */
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

/** * @section Uploads & Assets
 * @desc Ignore dynamic user uploads but keep the directory structure using .gitkeep.
 */
server/uploads/*
!server/uploads/.gitkeep

/** * @section Build & Distribution
 * @desc Ignore compiled code and production bundles.
 */
dist/
build/
client/dist/

/** * @section Logs & Debugging
 * @desc Ignore error logs and runtime debug information.
 */
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

/** * @section OS & IDE Junk
 * @desc Ignore system-specific files and local editor configurations.
 */
.DS_Store
.vscode/
.idea/
Thumbs.db