# .gitignore
# Specifies intentionally untracked files that Git should ignore.

# Dependencies
# Ignore all node_modules folders (local and nested).
**/node_modules/
node_modules/

# Security & Environment
# Prevent sensitive keys, passwords, and local configs from leaking.
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Uploads & Assets
# Ignore dynamic user uploads but keep the directory structure.
server/uploads/*
!server/uploads/.gitkeep

# Build & Distribution
# Ignore compiled code and production bundles.
dist/
build/
client/dist/

# Logs & Debugging
# Ignore error logs and runtime debug information.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS & IDE Junk
# Ignore system-specific files and local editor configurations.
.DS_Store
.vscode/
.idea/
Thumbs.db